<div class="topbar">
  <span class="brand"><span class="dot"></span> <%= t('app_name') %></span>
  <nav>
    <a href="<%= base %>/participants" class="<%= active === 'participants' ? 'active' : '' %>"><%= t('nav_participants') %></a>
    <a href="<%= base %>/draws" class="<%= active === 'draws' ? 'active' : '' %>"><%= t('nav_draws') %></a>
    <a href="<%= base %>/draws/history" class="<%= active === 'history' ? 'active' : '' %>"><%= t('nav_history') %></a>
    <a href="<%= base %>/account" class="<%= active === 'account' ? 'active' : '' %>"><%= t('nav_account') %></a>
  </nav>
  <span class="spacer"></span>

  <div class="lang-switch">
    <a href="<%= base %>/lang/uz" class="<%= lang === 'uz' ? 'active' : '' %>">UZ</a>
    <a href="<%= base %>/lang/ru" class="<%= lang === 'ru' ? 'active' : '' %>">RU</a>
    <a href="<%= base %>/lang/en" class="<%= lang === 'en' ? 'active' : '' %>">EN</a>
  </div>

  <button type="button" class="theme-toggle" id="themeToggle" title="<%= t('theme_toggle') %>" aria-label="<%= t('theme_toggle') %>">
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>

  <form method="post" action="<%= base %>/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <button type="submit" class="btn-ghost"><%= t('logout') %></button>
  </form>
</div>
