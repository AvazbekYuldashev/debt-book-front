<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="container">
  <div class="page-header">
    <h1><%= t('draws_title') %></h1>
    <p><%= t('draws_subtitle') %></p>
  </div>

  <div class="card">
    <div class="meta-row"><%= t('participant_count_label') %>: <strong><%= participantCount %></strong></div>
    <form method="post" action="<%= base %>/draws" class="form-row">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="field-inline">
        <%= t('prize_count_label') %>:
        <input type="number" name="prizeCount" min="1" max="1000" required class="num-sm" inputmode="numeric" />
      </div>
      <button type="submit">🎲 <%= t('run_draw_btn') %></button>
    </form>
    <% if (error) { %><div class="alert alert-error">⚠️ <%= t('draw_error_prefix') %>: <%= error %></div><% } %>
  </div>

  <% if (result) { %>
    <%# Natija SERVERDA to'liq chiqariladi (JS o'chiq bo'lsa ham hammasi ko'rinadi).
        JS yuklangach uni darhol maskalab, sahnaviy tartibda ochib boradi:
        o'rinlar soni -> telefon raqami raqamma-raqam -> ism familiya. %>
    <div class="card" id="drawResult">
      <h2><%= t('result_title') %> <span class="muted-count">Draw #<%= result.drawId %></span></h2>
      <div class="reveal-announce" id="revealAnnounce" data-count="<%= result.winners.length %>">
        🏆 <%= t('reveal_places', { count: result.winners.length }) %>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th><%= t('th_place') %></th><th><%= t('th_number') %></th><th><%= t('th_draw_name') %></th><th><%= t('th_phone') %></th></tr></thead>
          <tbody>
            <% result.winners.forEach((w, i) => { %>
              <tr class="reveal-row"
                  data-phone="<%= w.phone || '' %>"
                  data-name="<%= [w.name, w.surname].filter(Boolean).join(' ') || '-' %>">
                <td><span class="winner-badge">🏆 <%= i + 1 %></span></td>
                <td><span class="num-pill"><%= w.number %></span></td>
                <td><span class="reveal-name"><%= [w.name, w.surname].filter(Boolean).join(' ') || '-' %></span></td>
                <td class="dim"><span class="reveal-phone"><%= w.phone || '-' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>
<%- include('partials/scripts') %>
</body>
</html>
