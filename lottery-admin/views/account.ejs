<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="container">
  <div class="page-header">
    <h1><%= t('account_title') %></h1>
    <p><%= t('account_current_login') %>: <strong><%= username %></strong></p>
  </div>

  <div class="card" style="max-width: 420px;">
    <% if (error) { %><div class="alert alert-error">⚠️ <%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success">✅ <%= success %></div><% } %>
    <form method="post" action="<%= base %>/account" class="stack-form" style="margin-top: <%= (error || success) ? '16px' : '0' %>;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="field">
        <%= t('field_current_password') %>
        <input type="password" name="currentPassword" required />
      </div>
      <div class="field">
        <%= t('field_new_username') %>
        <input type="text" name="newUsername" value="<%= username %>" />
      </div>
      <div class="field">
        <%= t('field_new_password') %>
        <input type="password" name="newPassword" required minlength="10" />
      </div>
      <div class="field">
        <%= t('field_confirm_password') %>
        <input type="password" name="confirmPassword" required minlength="10" />
      </div>
      <button type="submit"><%= t('save_btn') %></button>
    </form>
  </div>
</div>
<%- include('partials/scripts') %>
</body>
</html>
