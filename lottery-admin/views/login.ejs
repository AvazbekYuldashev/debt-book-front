<%- include('partials/head') %>
<div class="login-wrap">
  <div class="login-card">
    <div class="lang-switch" style="position: absolute; top: 16px; right: 16px;">
      <a href="<%= base %>/lang/uz" class="<%= lang === 'uz' ? 'active' : '' %>">UZ</a>
      <a href="<%= base %>/lang/ru" class="<%= lang === 'ru' ? 'active' : '' %>">RU</a>
      <a href="<%= base %>/lang/en" class="<%= lang === 'en' ? 'active' : '' %>">EN</a>
    </div>
    <div class="logo"><span class="dot"></span> <%= t('app_name') %></div>
    <p class="sub"><%= t('login_sub') %></p>
    <% if (error) { %><div class="alert alert-error">⚠️ <%= error %></div><% } %>
    <form method="post" action="<%= base %>/login" class="stack-form" style="margin-top: 18px;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="text" name="username" placeholder="<%= t('login_username_placeholder') %>" required autofocus />
      <input type="password" name="password" placeholder="<%= t('login_password_placeholder') %>" required />
      <button type="submit"><%= t('login_btn') %></button>
    </form>
  </div>
</div>
<%- include('partials/scripts') %>
</body>
</html>
