# Namuna sozlamalar. Nusxa oling: cp .env.example .env
# ⚠️ .env fayli git'ga TUSHMAYDI (.gitignore) — haqiqiy kalitlarni faqat o'sha yerda saqlang.

# Ilova faqat localhost'da tinglaydi; tashqi kirish Apache/nginx (HTTPS) orqali proksi qilinadi.
HOST=127.0.0.1
PORT=4000
NODE_ENV=production

# Apache /lottery-admin prefiksi ostida proksi qilsa:
BASE_PATH=/lottery-admin

# Sessiya imzosi uchun tasodifiy kalit. Yaratish:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Faqat BIRINCHI ishga tushishda (bo'sh baza bilan) admin jadvalini urug'lash uchun ishlatiladi.
# Keyinchalik login/parol ilova ichidagi "Login/parolni o'zgartirish" sahifasida (SQLite'da) boshqariladi.
ADMIN_USERNAME=admin
# Parolning bcrypt hash'i — yaratish: node src/generate-hash.js "kuchli-parol"
ADMIN_PASSWORD_HASH=

# Debt-Book backendining ichki endpointi va uning kaliti (haqiqiy qiymatni .env ga yozing)
DEBT_BOOK_API_URL=https://pul-hisob.uz/api/v1/internal/lottery
DEBT_BOOK_INTERNAL_KEY=

DEFAULT_ACTIVE_DAYS=30
