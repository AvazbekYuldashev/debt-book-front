{
  "expo": {
    "name": "Debt Book",
    "slug": "debt-book",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "sdkVersion": "48.0.0",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSContactsUsageDescription": "Ilova telefon kontaktlaringizni mijoz sifatida qo'shish uchun foydalanadi."
      }
    },
    "android": {
      "package": "uz.debtbook.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_CONTACTS",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Debt Book",
      "shortName": "Debt Book",
      "lang": "uz",
      "description": "Debt Book - qarz daftari: mijozlar bilan oldi-berdi, balanslar va xarajatlarni yuritish uchun zamonaviy ilova.",
      "themeColor": "#0D9488",
      "backgroundColor": "#F1F5F9"
    },
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Ilova telefon kontaktlaringizni mijoz sifatida qo'shish uchun foydalanadi."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "54c2cc32-ddb3-4fde-97a1-239d1eadac69"
      }
    },
    "owner": "greed_coder"
  }
}
