{
  "expo": {
    "name": "Tez Top",
    "slug": "debt-book",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSContactsUsageDescription": "Ilova telefon kontaktlaringizni mijoz sifatida qo'shish uchun foydalanadi."
      }
    },
    "android": {
      "package": "uz.teztop.app",
      "versionCode": 16,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F1DB"
      },
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_CONTACTS",
        "android.permission.READ_CONTACTS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Tez Top",
      "shortName": "Tez Top",
      "lang": "uz",
      "description": "Tez Top: mijozlar bilan oldi-berdi, balanslar va xarajatlarni yuritish uchun zamonaviy ilova.",
      "themeColor": "#2BA24D",
      "backgroundColor": "#F1F5F9",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Ilova telefon kontaktlaringizni mijoz sifatida qo'shish uchun foydalanadi."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Ilova profil/biznes rasmini o'zgartirish uchun galereyangizdan foydalanadi.",
          "cameraPermission": false
        }
      ],
      "expo-build-properties"
    ],
    "extra": {
      "eas": {
        "projectId": "54c2cc32-ddb3-4fde-97a1-239d1eadac69"
      }
    },
    "owner": "greed_coder"
  }
}
